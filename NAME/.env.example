# PHC Exchange - Environment Variables

# ---- DATABASE ----
DATABASE_URL=postgresql+pg8000://phc_user:phc_password@localhost:5432/phc_exchange

# ---- JWT Security ----
SECRET_KEY=phc-exchange-super-secret-key-change-in-production-2024

# ---- Services ----
AI_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Optional: AI API Key ----
# Set this to enable Gemini-powered parsing and NL queries
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Optional: Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Optional: WhatsApp / Twilio ----
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
